# Runtime
NGAME_ENV=development

# Public URLs
FRONTEND_PUBLIC_URL=http://localhost:8080
API_PUBLIC_URL=http://localhost:8000
REALTIME_PUBLIC_URL=http://localhost:2567
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Ports published by Docker Compose
PUBLISH_ADDRESS=127.0.0.1
FRONTEND_PORT=8080
API_PORT=8000
REALTIME_PORT=2567
RECONNECT_TIMEOUT_SECONDS=30
MAX_ROOM_MESSAGES_PER_SECOND=20
FORWARDED_ALLOW_IPS=127.0.0.1

# PostgreSQL
POSTGRES_DB=ngame
POSTGRES_USER=ngame
POSTGRES_PASSWORD=replace-with-a-long-random-password
# Application JWT
JWT_ISSUER=http://localhost:8000
JWT_AUDIENCE=ngame
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=ngame_refresh
COOKIE_SECURE=false

# Google OpenID Connect
OAUTH_STATE_SECRET=replace-with-a-separate-long-random-secret
GOOGLE_AUTH_ENABLED=true
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
