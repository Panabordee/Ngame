# Runtime
NGAME_ENV=development
LOG_LEVEL=info

# Public URLs
FRONTEND_PUBLIC_URL=http://localhost:8080
API_PUBLIC_URL=http://localhost:8000
REALTIME_PUBLIC_URL=http://localhost:2567
CORS_ALLOWED_ORIGINS=http://localhost:8080
VITE_API_URL=http://localhost:8000
VITE_REALTIME_URL=http://localhost:2567

# Ports published by Docker Compose
PUBLISH_ADDRESS=127.0.0.1
FRONTEND_PORT=8080
API_PORT=8000
REALTIME_PORT=2567
REALTIME_HOST=0.0.0.0
RECONNECT_TIMEOUT_SECONDS=30
MAX_ROOM_MESSAGES_PER_SECOND=20
FORWARDED_ALLOW_IPS=127.0.0.1

# PostgreSQL
POSTGRES_DB=ngame
POSTGRES_USER=ngame
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql+psycopg://ngame:replace-with-a-long-random-password@postgres:5432/ngame

# Redis
REDIS_URL=redis://redis:6379/0

# Application JWT (mount the real files from ./secrets; never commit them)
JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
JWT_ISSUER=https://ngame-api.ce-nacl.com
JWT_AUDIENCE=ngame
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=ngame_refresh
COOKIE_SECURE=false

# Google OpenID Connect
OAUTH_STATE_SECRET=replace-with-a-separate-long-random-secret
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Email/password auth remains disabled in production until SMTP is configured.
EMAIL_AUTH_ENABLED=true
EMAIL_VERIFICATION_REQUIRED=false
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@ngame.ce-nacl.com

# Internal API authentication used by the realtime server when recording results.
REALTIME_INTERNAL_TOKEN=replace-with-a-separate-long-random-token
