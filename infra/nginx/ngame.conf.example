# Place this map in the nginx http context if it is not already defined.
map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
}

upstream ngame_frontend {
    server NGAME_VM_PRIVATE_IP:8080;
}

upstream ngame_api {
    server NGAME_VM_PRIVATE_IP:8000;
}

upstream ngame_realtime {
    server NGAME_VM_PRIVATE_IP:2567;
}

server {
    listen 443 ssl http2;
    server_name ngame.ce-nacl.com;

    # Configure certificate directives using the proxy's existing certificate workflow.

    location / {
        proxy_pass http://ngame_frontend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 443 ssl http2;
    server_name ngame-api.ce-nacl.com;

    location / {
        proxy_pass http://ngame_api;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 443 ssl http2;
    server_name ngame-realtime.ce-nacl.com;

    location / {
        proxy_pass http://ngame_realtime;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
